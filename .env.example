# API
NODE_ENV=development
API_PORT=3001
PUBLIC_WEB_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nela

# Redis optional
REDIS_URL=

# Google OAuth - backend only
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/v1/auth/google/callback

# JWT/session
JWT_ACCESS_SECRET=dev-change-me-access-secret-min-32-chars
REFRESH_TOKEN_PEPPER=dev-change-me-refresh-pepper
TOKEN_ENCRYPTION_KEY_BASE64=

# Razorpay - backend only
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_STARTER_ID=
RAZORPAY_PLAN_PRO_ID=

# OpenRouter - backend only
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://nela.ai
OPENROUTER_APP_TITLE=NELA

# Logging
LOG_LEVEL=info
PROMPT_LOGGING_ENABLED=false

# Next.js (web)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3000
