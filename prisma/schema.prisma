generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  oauthAccounts OAuthAccount[]
  devices       Device[]
  subscriptions Subscription[]
  entitlement   Entitlement?
  usageEvents   UsageEvent[]
  usageBuckets  UsageBucket[]
}

model OAuthAccount {
  id              String   @id @default(uuid())
  userId          String
  provider        String
  providerSubject String
  email           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
}

model DeviceLoginSession {
  id              String    @id @default(uuid())
  deviceCodeHash  String    @unique
  userCodeHash    String    @unique
  userCodeDisplay String
  deviceName      String?
  status          String // pending, approved, expired, denied
  approvedUserId  String?
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  approvedAt      DateTime?
}

model Device {
  id                    String    @id @default(uuid())
  userId                String
  deviceName            String?
  deviceFingerprintHash String?
  refreshTokenHash      String?
  revokedAt             DateTime?
  lastSeenAt            DateTime?
  createdAt             DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
}

model Subscription {
  id                     String    @id @default(uuid())
  userId                 String
  provider               String // razorpay
  razorpaySubscriptionId String?   @unique
  razorpayPlanId         String?
  plan                   String // starter, pro
  status                 String
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Entitlement {
  userId             String   @id
  cloudEnabled       Boolean  @default(false)
  plan               String   @default("free")
  status             String   @default("inactive")
  includedUsdMonthly Float    @default(0)
  maxInputTokens     Int      @default(0)
  maxOutputTokens    Int      @default(0)
  requestsPerMinute  Int      @default(0)
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageEvent {
  id               String   @id @default(uuid())
  userId           String
  requestId        String   @unique
  intent           String
  selectedModel    String
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  estimatedCostUsd Float?
  status           String
  errorCode        String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UsageBucket {
  id           String   @id @default(uuid())
  userId       String
  periodStart  DateTime
  periodEnd    DateTime
  usedUsd      Float    @default(0)
  requestCount Int      @default(0)
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodStart, periodEnd])
}

model RazorpayWebhookEvent {
  id              String   @id @default(uuid())
  razorpayEventId String?  @unique
  eventType       String
  payloadHash     String
  processedAt     DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
